<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      FINAL CLEAN FIX for:
      "style attribute 'attr/windowActionBar' not found"
      "style attribute 'attr/windowNoTitle' not found"

      Use ONLY Theme.Material3.Light.NoActionBar + android: versions.
      This is the only combination that works reliably in AGP 8.2+ with Compose.
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- These two lines are required -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>