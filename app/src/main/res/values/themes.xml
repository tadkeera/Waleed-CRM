<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      ========================================================
      FINAL DEFINITIVE FIX FOR THE EXACT ERROR IN YOUR LOG:
      "style attribute 'attr/windowActionBar' not found"
      "style attribute 'attr/windowNoTitle' not found"
      ========================================================

      Root cause: The resource merger is seeing legacy AppCompat attributes.

      ONLY working solution for Jetpack Compose + Material 3 + AGP 8.x:
      - Parent = Theme.Material3.Light.NoActionBar
      - Explicitly declare the two attributes using ONLY the android: prefix.
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- These two lines are what fixes the linking error -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>