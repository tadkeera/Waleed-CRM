<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      ========================================================
      DEFINITIVE FIX FOR THE EXACT ERROR IN YOUR LOGS:
      "style attribute 'attr/windowActionBar' not found"
      "style attribute 'attr/windowNoTitle' not found"
      ========================================================

      This error occurs in AGP 8.x when the resource merger
      sees references to old AppCompat attributes.

      ONLY WORKING SOLUTION:
      - Parent must be Theme.Material3.Light.NoActionBar
      - Declare ONLY the android: versions of the two attributes.
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- These two lines fix the "not found" error -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>