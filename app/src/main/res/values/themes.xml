<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      ========================================================
      DEFINITIVE ROOT-CAUSE FIX FOR THE EXACT ERROR IN LOGS:
      "style attribute 'attr/windowActionBar' not found"
      "style attribute 'attr/windowNoTitle' not found"
      ========================================================

      Root cause: During resource merging, something (library or generated code)
      is still referencing the old AppCompat attributes.

      SOLUTION: 
      - Use Theme.Material3.Light.NoActionBar as parent (modern)
      - Explicitly provide the two attributes with the `android:` namespace.
      This satisfies the linker without pulling legacy AppCompat code.
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- Explicitly provide the attributes that the merger is looking for -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>