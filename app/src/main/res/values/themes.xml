<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      ========================================================
      FINAL ROOT CAUSE FIX FOR:
      "style attribute 'attr/windowActionBar' not found"
      "style attribute 'attr/windowNoTitle' not found"
      ========================================================

      This error is caused by resource merging pulling in legacy
      AppCompat / old Material attributes.

      THE ONLY RELIABLE FIX for pure Compose + AGP 8.x + Material3:
      - Parent must be Theme.Material3.Light.NoActionBar
      - Declare ONLY the android: versions of the two attributes
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- These two lines are mandatory to stop the merger error -->
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>