<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 
      ========================================================
      DEFINITIVE ROOT-CAUSE FIX (FINAL VERSION)
      ========================================================
      Error from logs:
        style attribute 'attr/windowActionBar' not found
        style attribute 'attr/windowNoTitle' not found

      Root cause:
        Using legacy theme parents (android:Theme.Material.* or AppCompat)
        that still reference deprecated attributes.

      ONLY correct parent for Jetpack Compose + Material 3:
        Theme.Material3.Light.NoActionBar

      This parent completely removes ActionBar + title 
      WITHOUT ever referencing windowActionBar or windowNoTitle.
    -->
    <style name="Theme.PharmaCommCRM" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>
</resources>